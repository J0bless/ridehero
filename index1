// ThemeParks.wiki direct API (supports CORS from browsers - no proxy needed)
const TP_BASE = 'https://api.themeparks.wiki/v1/entity/';
const TP_IDS = {
  mk: '75ea578a-adc8-4116-a54d-dccb60765ef9',
  ep: '47f90d2c-e191-4239-a466-5892ef59a88b',
  hs: '288747d1-8b4f-4a64-867e-ea7c9b27bad8',
