// ── Rides screen ─────────────────────────────────────────────────────────────

async function reloadRides() {
  document.getElementById('rides-body').innerHTML = '<div class="loading"><div class="loading-spinner"></div><p>Loading wait times...</p></div>';
  document.getElementById('rides-footer').style.display = 'none';

  var tpId = TP_IDS[currentPark];
  var urls = [
    'https://api.themeparks.wiki/v1/entity/' + tpId + '/live',
    'https://corsproxy.io/?' + encodeURIComponent('https://api.themeparks.wiki/v1/entity/' + tpId + '/live'),
    PROXY_URL + '/waittimes?park=' + currentPark + '&source=auto'
  ];

  for (var i = 0; i < urls.length; i++) {
    try {
      var res = await fetch(urls[i]);
      if (!res.ok) throw new Error('HTTP ' + res.status);
      var data = await res.json();

      // themeparks.wiki direct or corsproxy response
      if (data.liveData) {
        rides = [];
        data.liveData.forEach(function(e) {
          if (e.entityType !== 'ATTRACTION' || e.status !== 'OPERATING') return;
          var wait = 0;
          if (e.queue && e.queue.STANDBY && e.queue.STANDBY.waitTime != null)
            wait = e.queue.STANDBY.waitTime;
          rides.push({ id: e.id, name: e.name, waitTime: wait, area: '' });
        });
      } else if (data.rides) {
        // proxy response
        rides = data.rides;
      } else {
        throw new Error('Unrecognised response format');
      }

      if (!rides.length) throw new Error('No open rides');
      rides.sort(function(a, b) { return a.waitTime - b.waitTime; });
      selected = new Set(rides.map(function(r) { return r.id; }));
      assignPositions();
      renderRides(i === 0 ? 'themeparks.wiki' : i === 1 ? 'themeparks.wiki (proxy)' : 'queue-times.com');
      document.getElementById('rides-footer').style.display = 'block';
      updateSelInfo();
      return;
    } catch(e) {
      console.warn('Source ' + i + ' failed: ' + e.message);
    }
  }

  document.getElementById('rides-body').innerHTML =
    '<div class="error-box"><p>Could not load wait times. Check your connection and try again.</p>' +
    '<button id="retry-btn">Try again</button></div>';
  var btn = document.getElementById('retry-btn');
  if (btn) btn.addEventListener('click', reloadRides);
}

function wc(w) { return w <= 20 ? 'wl' : w <= 45 ? 'wm' : 'wh'; }

function renderRides(source) {
  var html = '';
  if (source) {
    var cls = source.includes('themeparks') ? 'sc-tp' : 'sc-qt';
    var label = source.includes('themeparks') ? 'ThemeParks.wiki' : 'Queue-Times.com';
    html += '<div style="padding:10px 16px 2px;display:flex;align-items:center;gap:8px;"><span class="source-chip ' + cls + '">' + label + '</span><span style="font-size:12px;color:#8e8e93;">' + rides.length + ' open rides</span></div>';
  }
  html += '<div class="rides-list">';
  rides.forEach(function(r) {
    var on = selected.has(r.id);
    html += '<div class="ride-card' + (on ? ' on' : '') + '" data-id="' + r.id + '">' +
      '<div class="ride-check"><span class="ride-check-mark">✓</span></div>' +
      '<div class="ride-info"><div class="ride-name">' + r.name + '</div>' +
      (r.area ? '<div class="ride-area">' + r.area + '</div>' : '') + '</div>' +
      '<span class="wait-badge ' + wc(r.waitTime) + '">' + r.waitTime + 'm</span></div>';
