const PARK_BOXES = {
  mk:{minLat:28.418,maxLat:28.423,minLng:-81.586,maxLng:-81.574},
  ep:{minLat:28.372,maxLat:28.378,minLng:-81.552,maxLng:-81.546},
  hs:{minLat:28.354,maxLat:28.359,minLng:-81.565,maxLng:-81.558},
  ak:{minLat:28.354,maxLat:28.363,minLng:-81.595,maxLng:-81.587}
};

let currentMode = 'quick';
let currentPark = 'mk';
let rides = [];
let selected = new Set();
let priority = {};
let ridePos = {};
let routeOrder = [];
let hours = 13;

// ── Screen management ────────────────────────────────────────────────────────

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + id).classList.add('active');
  window.scrollTo(0, 0);
  var rf = document.getElementById('rides-footer');
  var pf = document.getElementById('priority-footer');
  if (rf) rf.style.display = (id === 'rides' && rides.length) ? 'block' : 'none';
  if (pf) pf.style.display = (id === 'priority') ? 'block' : 'none';
}

// ── Setup screen ─────────────────────────────────────────────────────────────

function selectMode(btn) {
  document.querySelectorAll('.mode-card').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  currentMode = btn.dataset.mode;
  document.getElementById('hours-section').style.display = currentMode === 'fullday' ? 'block' : 'none';
}

function selectPark(btn) {
