// ── GPS / distance helpers ────────────────────────────────────────────────────

function getRideCoords(name) {
  var lower = name.toLowerCase();
  var keys = Object.keys(RIDE_COORDS);
  for (var i = 0; i < keys.length; i++) {
    if (lower.includes(keys[i])) return RIDE_COORDS[keys[i]];
  }
  return null;
}

function distMetres(a, b) {
  var R = 6371000;
  var dLat = (b.lat - a.lat) * Math.PI / 180;
  var dLng = (b.lng - a.lng) * Math.PI / 180;
  var s = Math.pow(Math.sin(dLat/2), 2) + Math.cos(a.lat*Math.PI/180) * Math.cos(b.lat*Math.PI/180) * Math.pow(Math.sin(dLng/2), 2);
  return R * 2 * Math.atan2(Math.sqrt(s), Math.sqrt(1-s));
}

function walkMins(a, b) {
  var ca = getRideCoords(a.name);
  var cb = getRideCoords(b.name);
  if (!ca || !cb) return 8;
  return Math.round(distMetres(ca, cb) / 80 * 10) / 10;
}

function rideScore(current, candidate, isMust) {
  var walk = walkMins(current, candidate);
  return (isMust ? 0 : 20) + candidate.waitTime + walk * 1.5;
}

// ── Map position helpers ──────────────────────────────────────────────────────

function assignPositions() {
  ridePos = {};
  var zones = PARK_META[currentPark].zones || [];
  var box = PARK_BOXES[currentPark];
  var W = 1000, H = 620;
  rides.forEach(function(ride, i) {
    var coords = getRideCoords(ride.name);
    if (coords && box) {
      var x = 30 + ((coords.lng - box.minLng) / (box.maxLng - box.minLng)) * (W - 60);
      var y = 30 + ((box.maxLat - coords.lat) / (box.maxLat - box.minLat)) * (H - 60);
      ridePos[ride.id] = {x: Math.max(30, Math.min(W-30, x)), y: Math.max(30, Math.min(H-30, y))};
    } else {
      var z = zones[i % zones.length] || {x: W/2, y: H/2};
      var angle = (i / Math.max(rides.length, 1)) * Math.PI * 2;
      var radius = 48 + (i % 4) * 25;
      ridePos[ride.id] = {
        x: Math.max(30, Math.min(W-30, z.x + Math.cos(angle) * radius)),
        y: Math.max(30, Math.min(H-30, z.y + Math.sin(angle) * radius))
      };
    }
  });
}

