function toggleAll() {
  var btn = document.querySelector('.sm-btn.outline');
  if (selected.size === rides.length) {
    selected.clear();
    if (btn) btn.textContent = 'Select all';
  } else {
    rides.forEach(function(r) { selected.add(r.id); });
    if (btn) btn.textContent = 'Deselect all';
