function toggleRide(id) {
  if (selected.has(id)) selected.delete(id); else selected.add(id);
  var card = document.querySelector('.ride-card[data-id="' + id + '"]');
  if (card) card.classList.toggle('on', selected.has(id));
  updateSelInfo();
