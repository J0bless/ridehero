<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<title>Park Route Planner</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{-webkit-text-size-adjust:100%;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f2f2f7;color:#1c1c1e;min-height:100dvh;}
.screen{display:none;}.screen.active{display:block;}
.setup{padding:24px 20px 40px;}
.logo{display:flex;align-items:center;gap:10px;margin-bottom:20px;}
.logo-icon{width:44px;height:44px;background:#185FA5;border-radius:12px;display:flex;align-items:center;justify-content:center;}
.logo-icon svg{width:24px;height:24px;fill:none;stroke:#fff;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.logo h1{font-size:22px;font-weight:700;color:#1c1c1e;}
.logo p{font-size:13px;color:#8e8e93;margin-top:1px;}
.section-label{font-size:12px;font-weight:600;color:#8e8e93;text-transform:uppercase;letter-spacing:0.06em;margin:20px 0 8px;}
.inset-group{background:#fff;border-radius:12px;overflow:hidden;}
.inset-row{display:flex;align-items:center;gap:12px;padding:14px 16px;border-bottom:0.5px solid #e5e5ea;}
.inset-row:last-child{border-bottom:none;}
.inset-row label{font-size:15px;color:#1c1c1e;flex-shrink:0;}
.inset-row input[type=number]{width:60px;border:none;outline:none;font-size:15px;color:#185FA5;background:transparent;text-align:right;font-weight:600;}
.mode-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.mode-card{background:#fff;border-radius:14px;padding:18px 14px;border:2px solid transparent;cursor:pointer;transition:border-color 0.15s,background 0.15s;text-align:left;-webkit-tap-highlight-color:transparent;}
.mode-card.active{border-color:#185FA5;background:#f0f6ff;}
.mode-card .mode-icon{font-size:26px;display:block;margin-bottom:10px;}
.mode-card .mode-name{font-size:14px;font-weight:700;color:#1c1c1e;}
.mode-card .mode-sub{font-size:11px;color:#8e8e93;margin-top:4px;line-height:1.4;}
.mode-card.active .mode-name{color:#185FA5;}
.park-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.park-card{background:#fff;border-radius:14px;padding:16px 14px;border:2px solid transparent;cursor:pointer;transition:border-color 0.15s,background 0.15s;text-align:left;-webkit-tap-highlight-color:transparent;}
.park-card.active{border-color:#185FA5;background:#f0f6ff;}
.park-card .park-emoji{font-size:28px;display:block;margin-bottom:8px;}
.park-card .park-name{font-size:14px;font-weight:600;color:#1c1c1e;line-height:1.3;}
.park-card .park-sub{font-size:12px;color:#8e8e93;margin-top:2px;}
.cta{margin-top:28px;}
.big-btn{width:100%;padding:16px;background:#185FA5;color:#fff;border:none;border-radius:14px;font-size:17px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;-webkit-tap-highlight-color:transparent;}
.big-btn:active{opacity:0.85;}
.big-btn.secondary{background:#e5e5ea;color:#1c1c1e;}
.rides-screen{padding-bottom:100px;}
.top-bar{background:#fff;border-bottom:0.5px solid #e5e5ea;padding:12px 20px;display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:10;}
.back-btn{background:none;border:none;color:#185FA5;font-size:15px;font-weight:500;cursor:pointer;padding:4px 0;}
.top-bar-title{font-size:17px;font-weight:600;flex:1;}
.refresh-btn{background:none;border:none;color:#185FA5;font-size:22px;cursor:pointer;padding:4px;line-height:1;}
.source-chip{font-size:11px;font-weight:600;padding:3px 8px;border-radius:99px;}
.sc-tp{background:#dcfce7;color:#166534;}
.sc-qt{background:#fef9c3;color:#854d0e;}
.rides-list{padding:12px 16px;display:flex;flex-direction:column;gap:8px;}
.ride-card{background:#fff;border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:12px;border:2px solid transparent;cursor:pointer;-webkit-tap-highlight-color:transparent;}
.ride-card.on{border-color:#185FA5;background:#f0f6ff;}
.ride-check{width:24px;height:24px;border-radius:50%;border:2px solid #c7c7cc;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.ride-card.on .ride-check{background:#185FA5;border-color:#185FA5;}
.ride-check-mark{display:none;color:#fff;font-size:13px;font-weight:700;line-height:1;}
.ride-card.on .ride-check-mark{display:block;}
.ride-info{flex:1;min-width:0;}
.ride-name{font-size:15px;font-weight:500;color:#1c1c1e;line-height:1.3;}
.ride-area{font-size:12px;color:#8e8e93;margin-top:2px;}
.wait-badge{flex-shrink:0;padding:5px 11px;border-radius:99px;font-size:13px;font-weight:700;}
.wl{background:#dcfce7;color:#166534;}
.wm{background:#fef9c3;color:#854d0e;}
.wh{background:#fee2e2;color:#991b1b;}
.bottom-bar{position:fixed;bottom:0;left:0;right:0;padding:12px 20px;padding-bottom:max(12px,env(safe-area-inset-bottom));background:#f2f2f7;border-top:0.5px solid #e5e5ea;}
.sel-info{font-size:13px;color:#8e8e93;text-align:center;margin-bottom:8px;}
.bottom-actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.sm-btn{padding:13px;border-radius:12px;font-size:15px;font-weight:600;border:none;cursor:pointer;-webkit-tap-highlight-color:transparent;}
.sm-btn.outline{background:#fff;color:#185FA5;border:1.5px solid #185FA5;}
.sm-btn.filled{background:#185FA5;color:#fff;}
.priority-screen{padding-bottom:110px;}
.priority-list{padding:12px 16px;display:flex;flex-direction:column;gap:8px;}
.priority-card{background:#fff;border-radius:12px;padding:13px 16px;display:flex;align-items:center;gap:12px;border:2px solid transparent;cursor:pointer;-webkit-tap-highlight-color:transparent;transition:border-color 0.12s,background 0.12s;}
.priority-card.must{border-color:#ff9500;background:#fff8f0;}
.priority-card.want{border-color:#185FA5;background:#f0f6ff;}
.priority-dot{width:24px;height:24px;border-radius:50%;border:2px solid #c7c7cc;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:13px;}
.priority-card.must .priority-dot{background:#ff9500;border-color:#ff9500;color:#fff;}
.priority-card.want .priority-dot{background:#185FA5;border-color:#185FA5;color:#fff;}
.priority-name{font-size:15px;font-weight:500;color:#1c1c1e;}
.priority-area{font-size:12px;color:#8e8e93;margin-top:2px;}
.legend-row{display:flex;gap:14px;padding:10px 16px 4px;flex-wrap:wrap;}
.legend-item{display:flex;align-items:center;gap:6px;font-size:12px;color:#6b6b72;}
.legend-dot{width:12px;height:12px;border-radius:50%;}
.route-screen{padding-bottom:40px;}
.route-hero{color:#fff;padding:24px 20px 20px;}
.route-hero h2{font-size:20px;font-weight:700;margin-bottom:4px;}
.route-hero p{font-size:14px;opacity:0.85;line-height:1.5;}
.route-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:#e5e5ea;border-radius:14px;overflow:hidden;margin:16px 20px;}
.route-stat{background:#fff;padding:14px 10px;text-align:center;}
.route-stat-v{font-size:22px;font-weight:700;color:#1c1c1e;}
.route-stat-l{font-size:11px;color:#8e8e93;margin-top:3px;}
.map-section{margin:0 16px 16px;}
.map-section h3{font-size:13px;font-weight:600;color:#8e8e93;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;}
.map-wrap{background:#fff;border-radius:14px;overflow:hidden;}
.map-wrap svg{display:block;width:100%;height:auto;}
.steps-section{padding:0 16px;}
.steps-section h3{font-size:13px;font-weight:600;color:#8e8e93;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;}
.step-card{background:#fff;border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:14px;margin-bottom:8px;}
.step-num{width:32px;height:32px;border-radius:50%;background:#185FA5;color:#fff;font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.step-name{font-size:15px;font-weight:500;color:#1c1c1e;}
.step-wait{font-size:13px;color:#8e8e93;margin-top:2px;}
.walk-note{text-align:center;font-size:12px;color:#8e8e93;padding:4px 0 2px;}
.day-segment{margin:0 16px 12px;}
.seg-label{font-size:11px;font-weight:700;color:#8e8e93;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:8px;padding-left:4px;}
.seg-card{background:#fff;border-radius:12px;overflow:hidden;margin-bottom:6px;}
.seg-row{display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:0.5px solid #f3f4f6;}
.seg-row:last-child{border-bottom:none;}
.seg-time{font-size:12px;font-weight:600;color:#8e8e93;width:44px;flex-shrink:0;}
.seg-icon{font-size:16px;flex-shrink:0;width:22px;text-align:center;}
.seg-detail{flex:1;min-width:0;}
.seg-name{font-size:14px;font-weight:500;color:#1c1c1e;}
.seg-sub{font-size:12px;color:#8e8e93;margin-top:1px;}
.must-tag{font-size:10px;font-weight:700;padding:3px 8px;border-radius:99px;background:#fff3e0;color:#e65100;}
.loading{text-align:center;padding:60px 20px;}
.loading-spinner{width:36px;height:36px;border:3px solid #e5e5ea;border-top-color:#185FA5;border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 16px;}
@keyframes spin{to{transform:rotate(360deg);}}
.loading p{font-size:15px;color:#8e8e93;}
.error-box{margin:16px;background:#fff;border-radius:12px;padding:20px;text-align:center;}
.error-box p{font-size:14px;color:#ff3b30;line-height:1.5;}
.error-box button{margin-top:14px;padding:10px 24px;background:#185FA5;color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:600;cursor:pointer;}
</style>
</head>
<body>

<!-- SCREEN 1: Setup -->
<div class="screen active" id="screen-setup">
  <div class="setup">
    <div class="logo">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </div>
      <div>
        <h1>Park Planner</h1>
        <p>Disney World · Live wait times</p>
      </div>
    </div>

    <div class="section-label">Planning mode</div>
    <div class="mode-grid">
      <button class="mode-card active" data-mode="quick" onclick="selectMode(this)">
        <span class="mode-icon">⚡</span>
        <div class="mode-name">Quick picks</div>
        <div class="mode-sub">Next 3 rides, re-optimize as you go</div>
      </button>
      <button class="mode-card" data-mode="fullday" onclick="selectMode(this)">
        <span class="mode-icon">📅</span>
        <div class="mode-name">Full day plan</div>
        <div class="mode-sub">Complete schedule for your whole visit</div>
      </button>
    </div>

    <div id="hours-section" style="display:none">
      <div class="section-label">Park hours</div>
      <div class="inset-group">
        <div class="inset-row">
          <label>Opens at</label>
          <input type="number" id="open-hour" value="9" min="7" max="12"/>
          <span style="font-size:15px;color:#8e8e93;margin-left:4px;">am</span>
        </div>
        <div class="inset-row">
          <label>Closes at</label>
          <input type="number" id="close-hour" value="10" min="6" max="12"/>
          <span style="font-size:15px;color:#8e8e93;margin-left:4px;">pm</span>
        </div>
      </div>
    </div>

    <div class="section-label">Choose a park</div>
    <div class="park-grid">
      <button class="park-card active" data-park="mk" onclick="selectPark(this)">
        <span class="park-emoji">🏰</span>
        <div class="park-name">Magic Kingdom</div>
        <div class="park-sub">Classic Disney</div>
      </button>
      <button class="park-card" data-park="ep" onclick="selectPark(this)">
        <span class="park-emoji">🌍</span>
        <div class="park-name">EPCOT</div>
        <div class="park-sub">World & tech</div>
      </button>
      <button class="park-card" data-park="hs" onclick="selectPark(this)">
        <span class="park-emoji">🎬</span>
        <div class="park-name">Hollywood Studios</div>
        <div class="park-sub">Star Wars & more</div>
      </button>
      <button class="park-card" data-park="ak" onclick="selectPark(this)">
        <span class="park-emoji">🦁</span>
        <div class="park-name">Animal Kingdom</div>
        <div class="park-sub">Nature & Pandora</div>
      </button>
    </div>

    <div class="cta">
      <button class="big-btn" onclick="goToRides()">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        See wait times
      </button>
    </div>
  </div>
</div>

<!-- SCREEN 1b: Priority picker -->
<div class="screen" id="screen-priority">
  <div class="priority-screen">
    <div class="top-bar">
      <button class="back-btn" onclick="showScreen('rides')">‹ Back</button>
      <div class="top-bar-title">Pick your must-dos</div>
    </div>
    <div class="legend-row">
      <div class="legend-item"><div class="legend-dot" style="background:#ff9500"></div>Tap once = Must ride</div>
      <div class="legend-item"><div class="legend-dot" style="background:#185FA5"></div>Twice = Want to</div>
      <div class="legend-item"><div class="legend-dot" style="background:#e5e5ea"></div>Three times = Skip</div>
    </div>
    <div class="priority-list" id="priority-list"></div>
    <div class="bottom-bar" id="priority-footer" style="display:none">
      <div class="sel-info" id="priority-info"></div>
      <button class="big-btn" onclick="buildFullDayRoute()">Build my day plan →</button>
    </div>
  </div>
</div>

<!-- SCREEN 2: Rides -->
<div class="screen" id="screen-rides">
  <div class="rides-screen">
    <div class="top-bar">
      <button class="back-btn" onclick="showScreen('setup')">‹ Back</button>
      <div class="top-bar-title" id="rides-title">Magic Kingdom</div>
      <button class="refresh-btn" onclick="reloadRides()" aria-label="Refresh">↻</button>
    </div>
    <div id="rides-body">
      <div class="loading"><div class="loading-spinner"></div><p>Loading wait times...</p></div>
    </div>
    <div class="bottom-bar" id="rides-footer" style="display:none">
      <div class="sel-info" id="sel-info"></div>
      <div class="bottom-actions">
        <button class="sm-btn outline" onclick="toggleAll()">Select all</button>
        <button class="sm-btn filled" id="rides-cta-btn" onclick="handleRidesCTA()">Next →</button>
      </div>
    </div>
  </div>
</div>

<!-- SCREEN 3: Route -->
<div class="screen" id="screen-route">
  <div class="route-screen">
    <div class="top-bar">
      <button class="back-btn" id="route-back-btn" onclick="showScreen('rides')">‹ Rides</button>
      <div class="top-bar-title">Your route</div>
    </div>
    <div id="route-body"></div>
  </div>
</div>

