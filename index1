// ── Quick route (3 rides) ─────────────────────────────────────────────────────

function computeLocalRoute(sel) {
  if (!sel.length) return [];
  var remaining = sel.slice();
  var route = [];
  var current = {name:'entrance', waitTime:0};
  while (remaining.length && route.length < 3) {
    var best = null, bestScore = Infinity;
    remaining.forEach(function(r) {
      var s = r.waitTime + walkMins(current, r) * 1.5;
      if (s < bestScore) { bestScore = s; best = r; }
    });
    route.push(best);
    remaining.splice(remaining.indexOf(best), 1);
    current = best;
  }
  return route;
}

async function optimizeRoute() {
  var sel = rides.filter(function(r) { return selected.has(r.id); });
  if (sel.length < 2) { alert('Select at least 2 rides.'); return; }
  showScreen('route');
  document.getElementById('route-back-btn').onclick = function() { showScreen('rides'); };
  document.getElementById('route-body').innerHTML = '<div class="loading" style="padding-top:80px"><div class="loading-spinner"></div><p>Building your route...</p></div>';

  var meta = PARK_META[currentPark];
  var top3 = computeLocalRoute(sel);
  routeOrder = top3.map(function(r) { return r.id; });

  var walkLabels = [];
  for (var i = 0; i < top3.length - 1; i++) {
    var w = walkMins(top3[i], top3[i+1]);
    walkLabels.push(w < 1 ? '<1 min walk' : Math.round(w) + ' min walk');
  }

  var tip = 'Start with the closest high-demand ride, then work through the area.';
  try {
    var lines = top3.map(function(r) { return r.name + ': ' + r.waitTime + ' min wait'; }).join(', ');
    var res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({model:'claude-sonnet-4-6', max_tokens:120, messages:[{role:'user',
        content:'Disney World ' + meta.name + '. These 3 rides are in optimal order: ' + lines + '. Give one short practical tip (under 20 words). Plain text only.'}]})
    });
    var d = await res.json();
    tip = d.content.map(function(b) { return b.text || ''; }).join('').trim();
  } catch(e) {}

  var totalWait = top3.reduce(function(s,r) { return s + r.waitTime; }, 0);
  var totalWalk = top3.reduce(function(s,r,i) { return i === 0 ? s : s + walkMins(top3[i-1], r); }, 0);
  var totalTime = totalWait + Math.round(totalWalk) + top3.length * 5;
  var heroBg = HERO_COLORS[currentPark] || '#185FA5';

  var mapSvg = buildMap(routeOrder);
  var html = '<div class="route-hero" style="background:' + heroBg + '"><h2>' + meta.emoji + ' Next 3 rides</h2><p>' + tip + '</p></div>' +
    '<div class="route-stats"><div class="route-stat"><div class="route-stat-v">' + top3.length + '</div><div class="route-stat-l">rides</div></div>' +
    '<div class="route-stat"><div class="route-stat-v">' + Math.round(totalWait) + 'm</div><div class="route-stat-l">wait time</div></div>' +
    '<div class="route-stat"><div class="route-stat-v">' + Math.round(totalTime) + 'm</div><div class="route-stat-l">total time</div></div></div>' +
    '<div class="map-section"><h3>Route map</h3><div class="map-wrap" id="map-container"></div></div>' +
    '<div class="steps-section"><h3>Your next stops</h3>';

  top3.forEach(function(ride, i) {
    var walkNote = i < walkLabels.length ? '<div class="walk-note">↓ ' + walkLabels[i] + '</div>' : '';
    html += '<div class="step-card"><div class="step-num">' + (i+1) + '</div>' +
      '<div style="flex:1"><div class="step-name">' + ride.name + '</div>' +
      '<div class="step-wait">' + ride.waitTime + ' min wait' + (ride.area ? ' · ' + ride.area : '') + '</div></div>' +
      '<span class="wait-badge ' + wc(ride.waitTime) + '">' + ride.waitTime + 'm</span></div>' + walkNote;
  });

  var remaining = sel.filter(function(r) { return routeOrder.indexOf(r.id) < 0; });
  if (remaining.length) {
    html += '<div style="margin-top:16px;padding:14px 16px;background:#fff;border-radius:12px;">' +
      '<div style="font-size:12px;font-weight:600;color:#8e8e93;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px;">After these 3</div>';
    remaining.forEach(function(r) {
      html += '<div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:0.5px solid #f3f4f6;">' +
        '<span style="font-size:14px;color:#6b7280;">' + r.name + '</span>' +
        '<span class="wait-badge ' + wc(r.waitTime) + '">' + r.waitTime + 'm</span></div>';
    });
    html += '</div>';
  }

  html += '</div><div style="margin:16px;display:grid;grid-template-columns:1fr 1fr;gap:10px;">' +
    '<button class="sm-btn outline" id="back-rides-btn">‹ Back</button>' +
    '<button class="sm-btn filled" id="reopt-btn">Re-optimize</button></div>';

  document.getElementById('route-body').innerHTML = html;
  document.getElementById('map-container').appendChild(mapSvg);
  document.getElementById('back-rides-btn').onclick = function() { showScreen('rides'); };
  document.getElementById('reopt-btn').onclick = reoptimize;
}

function reoptimize() {
  if (routeOrder.length > 0) selected.delete(routeOrder[0]);
  optimizeRoute();
}

// ── Priority picker ───────────────────────────────────────────────────────────

function openPriorityPicker() {
  priority = {};
  rides.forEach(function(r) { priority[r.id] = 'skip'; });
  renderPriorityList();
  showScreen('priority');
  var pf = document.getElementById('priority-footer');
  if (pf) pf.style.display = 'block';
}

function renderPriorityList() {
  var mustCount = Object.values(priority).filter(function(v) { return v === 'must'; }).length;
  var wantCount = Object.values(priority).filter(function(v) { return v === 'want'; }).length;
  var info = document.getElementById('priority-info');
  if (info) info.textContent = mustCount + ' must-dos · ' + wantCount + ' want-to-dos';
  var list = document.getElementById('priority-list');
  list.innerHTML = '';
  rides.forEach(function(r) {
    var p = priority[r.id] || 'skip';
    var icons = {must:'★', want:'✓', skip:''};
    var div = document.createElement('div');
    div.className = 'priority-card' + (p === 'must' ? ' must' : p === 'want' ? ' want' : '');
    div.innerHTML = '<div class="priority-dot">' + (icons[p] || '') + '</div>' +
      '<div style="flex:1"><div class="priority-name">' + r.name + '</div>' +
      (r.area ? '<div class="priority-area">' + r.area + ' · ' + r.waitTime + ' min wait</div>' : '') + '</div>' +
      '<span class="wait-badge ' + wc(r.waitTime) + '">' + r.waitTime + 'm</span>';
    div.addEventListener('click', function() {
      var cur = priority[r.id] || 'skip';
      priority[r.id] = cur === 'skip' ? 'must' : cur === 'must' ? 'want' : 'skip';
      renderPriorityList();
    });
    list.appendChild(div);
  });
}

// ── Full day route ────────────────────────────────────────────────────────────

async function buildFullDayRoute() {
  showScreen('route');
  document.getElementById('route-back-btn').onclick = function() { showScreen('priority'); };
  document.getElementById('route-body').innerHTML = '<div class="loading" style="padding-top:80px"><div class="loading-spinner"></div><p>Building your full day...</p></div>';

  var meta = PARK_META[currentPark];
  var mustRides = rides.filter(function(r) { return priority[r.id] === 'must'; });
  var wantRides = rides.filter(function(r) { return priority[r.id] === 'want'; });
  var allRides = mustRides.concat(wantRides);

  if (!allRides.length) {
    document.getElementById('route-body').innerHTML = '<div class="error-box"><p>Pick at least one must-do or want-to ride first.</p><button id="err-back-btn">‹ Go back</button></div>';
    var eb = document.getElementById('err-back-btn');
    if (eb) eb.onclick = function() { showScreen('priority'); };
    return;
  }

  var budgetMins = hours * 60;
  var remaining = allRides.slice();
  var fullRoute = [];
  var elapsed = 0;
  var current = {name:'entrance', waitTime:0};

  while (remaining.length && elapsed < budgetMins - 20) {
    var musts = remaining.filter(function(r) { return priority[r.id] === 'must'; });
    var pool = musts.length ? musts : remaining;
    var best = null, bestScore = Infinity;
    pool.forEach(function(r) {
      var walk = walkMins(current, r);
      var s = (priority[r.id] === 'must' ? 0 : 20) + r.waitTime + walk * 1.5;
      if (s < bestScore) { bestScore = s; best = r; }
    });
    var walk = current.name === 'entrance' ? 5 : walkMins(current, best);
    var rideCost = best.waitTime + walk + 5;
    if (elapsed + rideCost > budgetMins) break;
    fullRoute.push({ride:best, walkFromPrev:Math.round(walk), startMin:Math.round(elapsed + walk)});
    elapsed += rideCost;
    remaining.splice(remaining.indexOf(best), 1);
    current = best;
  }

  routeOrder = fullRoute.map(function(s) { return s.ride.id; });

  var tip = 'Must-dos are prioritized early, then grouped by area to minimize walking.';
  try {
    var lines = fullRoute.map(function(s, i) {
      return (i+1) + '. ' + s.ride.name + ' (' + (priority[s.ride.id] === 'must' ? 'MUST' : 'want') + ', ' + s.ride.waitTime + 'min)';
    }).join(', ');
    var res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({model:'claude-sonnet-4-6', max_tokens:100, messages:[{role:'user',
        content:'Disney World ' + meta.name + ', ' + hours + 'hr visit. Order: ' + lines + '. One practical tip (under 20 words). Plain text only.'}]})
    });
    var d = await res.json();
    tip = d.content.map(function(b) { return b.text || ''; }).join('').trim();
  } catch(e) {}

  var mapSvg = buildMap(routeOrder);
  var heroBg = HERO_COLORS[currentPark] || '#185FA5';
  var openHour = currentMode === 'fullday' ? (parseInt(document.getElementById('open-hour').value) || 9) : 9;

  function minToTime(min) {
    var total = openHour * 60 + min;
    var h = Math.floor(total / 60);
    var m = total % 60;
    var ampm = h >= 12 ? 'pm' : 'am';
    var disp = h > 12 ? h - 12 : h === 0 ? 12 : h;
    return disp + ':' + (m < 10 ? '0' : '') + m + ampm;
  }

  var totalWait = fullRoute.reduce(function(s,r) { return s + r.ride.waitTime; }, 0);
  var mustDone = mustRides.filter(function(r) { return fullRoute.find(function(s) { return s.ride.id === r.id; }); }).length;
  var heroBg2 = HERO_COLORS[currentPark] || '#185FA5';

  var html = '<div class="route-hero" style="background:' + heroBg2 + '"><h2>' + meta.emoji + ' Your full day</h2><p>' + tip + '</p></div>' +
    '<div class="route-stats">' +
    '<div class="route-stat"><div class="route-stat-v">' + fullRoute.length + '</div><div class="route-stat-l">rides</div></div>' +
    '<div class="route-stat"><div class="route-stat-v">' + mustDone + '</div><div class="route-stat-l">must-dos</div></div>' +
    '<div class="route-stat"><div class="route-stat-v">' + Math.round(totalWait) + 'm</div><div class="route-stat-l">total wait</div></div>' +
    '</div><div class="map-section"><h3>Full day route</h3><div class="map-wrap" id="map-container"></div></div>';

  var totalMins = hours * 60;
  var third = totalMins / 3;
  var segments = [
    {label:'Morning', icon:'🌅', rides:fullRoute.filter(function(s) { return s.startMin < third; })},
    {label:'Afternoon', icon:'☀️', rides:fullRoute.filter(function(s) { return s.startMin >= third && s.startMin < third * 2; })},
    {label:'Evening', icon:'🌙', rides:fullRoute.filter(function(s) { return s.startMin >= third * 2; })}
  ];

  segments.forEach(function(seg) {
    if (!seg.rides.length) return;
    html += '<div class="day-segment"><div class="seg-label">' + seg.icon + ' ' + seg.label + '</div><div class="seg-card">';
    seg.rides.forEach(function(s) {
      var isMust = priority[s.ride.id] === 'must';
      var walkNote = s.walkFromPrev > 0 ? ' · ' + s.walkFromPrev + ' min walk' : '';
      html += '<div class="seg-row">' +
        '<div class="seg-time">' + minToTime(s.startMin) + '</div>' +
        '<div class="seg-icon">' + (isMust ? '★' : '·') + '</div>' +
        '<div class="seg-detail"><div class="seg-name">' + s.ride.name + '</div>' +
        '<div class="seg-sub">' + s.ride.waitTime + ' min wait' + walkNote + '</div></div>' +
        '<div>' + (isMust ? '<span class="must-tag">MUST</span>' : '') + '</div></div>';
    });
    html += '</div></div>';
  });

  if (remaining.length) {
    html += '<div class="day-segment"><div class="seg-label">⏭ Didn&#39;t fit today</div><div class="seg-card">';
    remaining.forEach(function(r) {
      html += '<div class="seg-row">' +
        '<div class="seg-time" style="color:#c7c7cc;">—</div>' +
        '<div class="seg-icon" style="opacity:0.4">·</div>' +
        '<div class="seg-detail"><div class="seg-name" style="color:#8e8e93;">' + r.name + '</div>' +
        '<div class="seg-sub">' + r.waitTime + ' min wait</div></div>' +
        '<span class="wait-badge ' + wc(r.waitTime) + '">' + r.waitTime + 'm</span></div>';
    });
    html += '</div></div>';
  }

  html += '<div style="margin:8px 16px 32px;display:grid;grid-template-columns:1fr 1fr;gap:10px;">' +
    '<button class="sm-btn outline" id="adjust-btn">‹ Adjust</button>' +
    '<button class="sm-btn filled" id="livewaits-btn">Live waits</button></div>';

  document.getElementById('route-body').innerHTML = html;
  document.getElementById('map-container').appendChild(mapSvg);
  document.getElementById('adjust-btn').onclick = function() { showScreen('priority'); };
  document.getElementById('livewaits-btn').onclick = function() { showScreen('rides'); };
}
</script>
</body>
</html>
